# ── Copy this file to .env and fill in your real values ──────────────────────
# cp .env.example .env

# LLM Provider: "groq" or "openai"
LLM_PROVIDER=groq

# Groq (get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional, only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Reranker
ENABLE_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Qdrant Cloud (get free cluster at https://cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
COLLECTION_NAME=website_chunks

# Chunking settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval settings
TOP_K=5
ENABLE_HYBRID=false

# Crawler settings
MAX_PAGES=120
REQUEST_TIMEOUT=15
CRAWL_DELAY=0.5

# Redis cache (optional - leave blank to disable)
REDIS_URL=
